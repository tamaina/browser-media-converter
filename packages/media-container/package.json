{
  "name": "@browser-avif-lab/media-container",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @browser-avif-lab/binary build",
    "build": "esbuild src/index.ts --bundle --format=esm --platform=neutral --target=es2022 --outfile=dist/index.js && tsc -p tsconfig.json --emitDeclarationOnly",
    "pretypecheck": "pnpm --filter @browser-avif-lab/binary build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test test/avif.test.mjs"
  },
  "dependencies": {
    "@browser-avif-lab/binary": "workspace:*"
  }
}
